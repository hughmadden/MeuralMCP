[Unit]
Description=MeuralMCP preview reload daemon
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
Environment=MEURAL_MCP_STORAGE_DIR=%h/.config/meural-mcp
ExecStart=%h/.local/bin/meural-mcp --storage-dir %h/.config/meural-mcp daemon
Restart=always
RestartSec=15

[Install]
WantedBy=default.target
